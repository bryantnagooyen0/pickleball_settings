{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "installCommand": "npm install",
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    {
      "source": "/sitemap.xml",
      "destination": "https://pickleball-settings.onrender.com/sitemap.xml"
    },
    { "source": "/(.*)", "destination": "/" }
  ]
}
